{
  "format_version": "1.13.0",
  "minecraft:tree_feature": {
    "description": {
      "identifier": "minecraft:undecorated_jungle_tree_feature"
    },

    "trunk": {
      "trunk_height": { "range_min": 1, "range_max": 1 },
      "trunk_block": { "name": "minecraft:log" }
    },

    "canopy": {
      "canopy_offset": { "min": 0, "max": 0 },
      "variation_chance": 1.0,
      "leaf_block": { "name": "minecraft:leaves" }
    },

    "base_block": ["minecraft:dirt", "minecraft:coarse_dirt"],

    "may_grow_on": [
      "minecraft:dirt",
      "minecraft:grass_block",
      "minecraft:podzol",
      "minecraft:mycelium",
      "minecraft:coarse_dirt"
    ],

    "may_replace": [
      "minecraft:air",
      {
        "name": "minecraft:leaves",
        "states": { "old_leaf_type": "jungle" }
      }
    ],

    "may_grow_through": [
      "minecraft:dirt",
      "minecraft:grass_block",
      "minecraft:coarse_dirt"
    ]
  }
}
